# DirectQR standalone product. Use a brand-new PostgreSQL database; never point
# this package at the DirectQR database.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://directqr:directqr_local_password@localhost:5432/directqr

# 32+ random characters. Keep this private and different from every password.
AUTH_PASSWORD_PEPPER=replace_with_a_long_random_secret_before_production

# Created once when the DirectQR database has no Super Admin user.
SUPER_ADMIN_USERNAME=directqr-admin
SUPER_ADMIN_PASSWORD=replace_with_a_unique_12_plus_character_password
SUPER_ADMIN_DISPLAY_NAME=DirectQR Super Admin

# Exact browser URL. On Render, set both to the DirectQR Web Service URL.
APP_ORIGIN=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
TRUST_PROXY=false
DEFAULT_VOID_PASSWORD=Void@2026!

# Web Push / PWA order notifications. Generate with:
# npm run push:keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-support-email@example.com
